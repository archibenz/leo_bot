# Telegram Bot (aiogram) — переменные окружения
# Скопируй в .env и заполни реальными значениями. .env в gitignore.

# === Telegram ===
# Получить у @BotFather: /newbot или /token
BOT_TOKEN=

# === API связь ===
API_BASE_URL=https://reinasleo.com/api
# Должен совпадать с BOT_API_SECRET на backend (apps/api/.env)
BOT_API_SECRET=

# === Админы ===
# Comma-separated Telegram user IDs, которым разрешена админ-панель
ADMIN_IDS=

# === Публичные URL ===
SITE_URL=https://reinasleo.com
PAGES_URL=https://reinasleo.com

# === Legacy (старый прототип, можно удалить если не используется) ===
# SHEET_ID=
